generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Organization {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  address      String?
  contactPerson String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  customers        Customer[]
  vendors          Vendor[]
  salesInvoices    SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
}

  model Customer {
  id                      String   @id @default(uuid())
  customer_id             String   @unique
  company_name            String
  contact_person          String
  designation             String
  email                   String
  mobile                  String
  alternate_phone         String?
  billing_address_line1   String
  billing_address_line2   String?
  city                    String
  state                   String
  pincode                 String
  country                 String
  gstin                   String?
  pan_number              String?
  gst_type                String?
  place_of_supply         String?
  industry                String?
  credit_limit            Decimal? @db.Decimal(18, 2)
  payment_terms_days      Int?
  preferred_payment_method String?
  bank_name               String?
  bank_account_no         String?
  bank_ifsc               String?
  bank_branch            String?
  currency                String   @default("INR")
  tds_applicable          Boolean  @default(false)
  tds_rate_pct            Decimal? @db.Decimal(5, 2)
  customer_since          DateTime?
  account_manager         String?
  credit_rating           String?
  status                  CustomerStatus @default(Active)
  remarks                 String?
  outstanding_balance     Decimal  @default(0) @db.Decimal(18, 2)
  credit_utilisation_pct  Decimal  @default(0) @db.Decimal(5, 2)
  avg_payment_days        Int      @default(0)
  last_payment_date       DateTime?
  total_invoices          Int      @default(0)
  overdue_invoices_count  Int      @default(0)
  payment_behavior_tag    String?
  ai_risk_score           Decimal  @default(0) @db.Decimal(5, 2)
  company_id              String
  organization            Organization @relation(fields: [company_id], references: [id])
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt
  created_by              String   @default("system")

  @@index([company_id])
  @@index([customer_id])
  @@index([email])
  salesInvoices           SalesInvoice[]
}

model Vendor {
  id                        String   @id @default(uuid())
  vendor_id                 String   @unique
  company_name              String
  contact_person            String
  designation               String
  email                     String
  mobile                    String
  alternate_phone           String?
  billing_address_line1     String
  billing_address_line2     String?
  city                      String
  state                     String
  pincode                   String
  country                   String
  gstin                     String?
  pan_number                String?
  gst_type                  String?
  vendor_category           VendorCategory?
  payment_terms_days        Int?
  preferred_payment_method   String?
  bank_name                 String?
  bank_account_no         String?
  bank_ifsc                 String?
  bank_branch               String?
  currency                  String   @default("INR")
  tds_applicable            Boolean  @default(false)
  tds_rate_pct              Decimal? @db.Decimal(5, 2)
  msme_registered           Boolean  @default(false)
  msme_number               String?
  vendor_since              DateTime?
  vendor_credit_limit       Decimal? @db.Decimal(18, 2)
  rating                    String?
  lead_time_days            Int?
  status                    VendorStatus @default(Active)
  remarks                   String?
  outstanding_payable       Decimal  @default(0) @db.Decimal(18, 2)
  avg_payment_days          Int      @default(0)
  total_bills               Int      @default(0)
  overdue_bills_count       Int      @default(0)
  last_payment_date         DateTime?
  last_transaction_date     DateTime?
  payment_behavior_tag      String?
  company_id                String
  organization              Organization @relation(fields: [company_id], references: [id])
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
  created_by                String   @default("system")

  @@unique([company_id, vendor_id])
  @@index([company_id])
  @@index([company_id, email])
  purchaseInvoices        PurchaseInvoice[]
}

model SalesInvoice {
  id                  String              @id @default(uuid())
  invoice_no          String
  invoice_date        DateTime
  customer_id_ref     String              // Reference to Customer.customer_id
  customer            Customer            @relation(fields: [customer_id_ref], references: [customer_id])
  payment_terms_days  Int?
  due_date            DateTime?
  total_amount        Decimal             @db.Decimal(18, 2)
  paid_amount         Decimal             @default(0) @db.Decimal(18, 2)
  status              SalesInvoiceStatus  @default(Pending)
  place_of_supply     String?
  company_id          String
  organization        Organization        @relation(fields: [company_id], references: [id])
  items               SalesInvoiceItem[]
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  @@unique([company_id, invoice_no])
  @@index([company_id])
  @@index([customer_id_ref])
  @@index([invoice_no])
}

model SalesInvoiceItem {
  id          String       @id @default(uuid())
  invoice_id  String
  invoice     SalesInvoice @relation(fields: [invoice_id], references: [id])
  item_id     String?
  item_name   String
  quantity    Decimal      @db.Decimal(18, 2)
  unit        String?
  unit_price  Decimal      @db.Decimal(18, 2)
  gst_rate    Decimal      @default(0) @db.Decimal(5, 2)
  cgst        Decimal      @default(0) @db.Decimal(18, 2)
  sgst        Decimal      @default(0) @db.Decimal(18, 2)
  igst        Decimal      @default(0) @db.Decimal(18, 2)
  total       Decimal      @db.Decimal(18, 2)

  @@index([invoice_id])
}

model PurchaseInvoice {
  id                    String                @id @default(uuid())
  invoice_no            String
  invoice_date          DateTime
  vendor_id             String                // Foreign key referencing Vendor.id (UUID)
  vendor                Vendor                @relation(fields: [vendor_id], references: [id])
  payment_terms_days    Int?
  due_date              DateTime?
  total_amount          Decimal               @db.Decimal(18, 2)
  paid_amount           Decimal               @default(0) @db.Decimal(18, 2)
  tds_deducted          Decimal               @default(0) @db.Decimal(18, 2)
  grn_number            String?
  po_number             String?
  company_id            String
  organization          Organization          @relation(fields: [company_id], references: [id])
  status                PurchaseInvoiceStatus @default(Pending)
  remarks               String?
  items                 PurchaseInvoiceItem[]
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt

  @@unique([company_id, invoice_no])
  @@index([company_id])
  @@index([vendor_id])
  @@index([invoice_no])
}

model PurchaseInvoiceItem {
  id          String          @id @default(uuid())
  invoice_id  String
  invoice     PurchaseInvoice @relation(fields: [invoice_id], references: [id])
  item_name   String
  quantity    Decimal         @db.Decimal(18, 2)
  unit        String?
  unit_price  Decimal         @db.Decimal(18, 2)
  gst_rate    Decimal         @default(0) @db.Decimal(5, 2)
  cgst        Decimal         @default(0) @db.Decimal(18, 2)
  sgst        Decimal         @default(0) @db.Decimal(18, 2)
  igst        Decimal         @default(0) @db.Decimal(18, 2)
  total       Decimal         @db.Decimal(18, 2)

  @@index([invoice_id])
}

enum PurchaseInvoiceStatus {
  Pending
  Paid
  PartiallyPaid
  Overdue
  Cancelled
}

enum SalesInvoiceStatus {
  Pending
  Paid
  PartiallyPaid
  Overdue
  Cancelled
}

enum CustomerStatus {
  Active
  Inactive
}

enum VendorStatus {
  Active
  Inactive
  OnHold
  Blacklisted
}

enum VendorCategory {
  RawMaterial
  Consumables
  Services
  CapitalGoods
}
